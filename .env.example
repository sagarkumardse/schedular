APP_ENV=local
## Comma-separated list. Local example:
## CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
## Prod example:
## CORS_ORIGINS=https://schedular-production-25b6.up.railway.app
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

GROQ_API_KEY=your_groq_api_key_here
## Use either GOOGLE_CREDENTIALS_JSON_B64 or GOOGLE_CREDENTIALS_FILE
GOOGLE_CREDENTIALS_FILE=scripts/creds.json
## Local file token mode:
GOOGLE_TOKEN_FILE=token.pickle
## For env-token mode (recommended for Railway), set empty:
## GOOGLE_TOKEN_FILE=
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/callback
GOOGLE_OAUTH_FORCE_CONSENT=false
RETURN_TOKEN_B64_IN_CALLBACK=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM=your_email@example.com
SMTP_USE_TLS=true
PARSER_MODEL=llama-3.3-70b-versatile
GOOGLE_CREDENTIALS_JSON_B64=""
GOOGLE_TOKEN_PICKLE_B64=""
